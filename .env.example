# MUSIC_SIDECAR_DIR=/data/music-bin
# YTDLP_PATH=
# FFMPEG_PATH=

# Optional env overrides. Prefer panda.config.json for non-secret settings.
# OWNER_USER_IDS=
# PANDA_CONFIG=panda.config.json
# PANDA_ENV_FILE=.env
