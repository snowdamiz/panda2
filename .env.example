# Required settings for live integrations.
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=

OPENROUTER_API_KEY=
# OPENROUTER_DEFAULT_MODEL=inception/mercury-2
# OPENROUTER_CLASSIFIER_MODEL=inclusionai/ling-2.6-flash

# Optional secret for the Brave Search-backed web.search tool.
