---
/**
 * Panel header: a title with an optional inline badge (pill/count) and an
 * optional `actions` slot (search form, controls).
 */
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<header class="dash-panel-head">
  <div class="dash-panel-title">
    <h2>{title}</h2>
    <slot name="badge" />
  </div>
  <slot name="actions" />
</header>
