---
interface Props {
  href: string;
  variant?: 'light' | 'ghost' | 'dark' | 'outlineDark';
  external?: boolean;
  class?: string;
  ariaLabel?: string;
  target?: string;
  rel?: string;
}

const {
  href,
  variant = 'light',
  external = false,
  class: className = '',
  ariaLabel,
  target: targetProp,
  rel: relProp,
} = Astro.props;

const variantClass = {
  light: 'button-light',
  ghost: 'button-ghost',
  dark: 'button-dark',
  outlineDark: 'button-outline-dark',
}[variant];
const target = targetProp ?? (external ? '_blank' : undefined);
const rel = relProp ?? (external ? 'noreferrer' : undefined);
---

<a class:list={['button', variantClass, className]} href={href} target={target} rel={rel} aria-label={ariaLabel}>
  <slot />
</a>
