---
interface Props {
  variant?: 'avatar' | 'cta';
}

const { variant = 'avatar' } = Astro.props;
---

{
  variant === 'cta' ? (
    <svg viewBox="0 0 120 120">
      <circle cx="35" cy="34" r="20" />
      <circle cx="85" cy="34" r="20" />
      <ellipse cx="60" cy="65" rx="45" ry="42" class="cta-face" />
      <ellipse cx="44" cy="60" rx="12" ry="16" />
      <ellipse cx="76" cy="60" rx="12" ry="16" />
      <path d="M51 84c5 4 13 4 18 0" />
    </svg>
  ) : (
    <svg viewBox="0 0 30 30">
      <circle cx="9" cy="9" r="5" />
      <circle cx="21" cy="9" r="5" />
      <ellipse cx="15" cy="16" rx="11" ry="10" class="face" />
      <ellipse cx="11" cy="15" rx="3" ry="4" />
      <ellipse cx="19" cy="15" rx="3" ry="4" />
      <path d="M13 21c1.2.9 2.8.9 4 0" />
    </svg>
  )
}
