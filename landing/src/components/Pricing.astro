---
import { packOptions, trialPack, actionCosts, siteMeta } from '../data/landing';
import Kicker from './ui/Kicker.astro';

const packRows = [
  {
    label: 'Credits',
    values: packOptions.map((pack) => pack.credits.replace(' credits', '')),
  },
  {
    label: 'Knowledge',
    values: packOptions.map((pack) => pack.storage.replace(' knowledge', '')),
  },
  {
    label: 'Retention',
    values: packOptions.map((pack) => pack.retention.replace('-day retention', ' days')),
  },
];

const packCheckoutUrl = (slug: string) => `${siteMeta.billingUrl}?pack=${slug}`;
const actionCostSummary = actionCosts.map((item) => `${item.action} ${item.cost}`).join(' · ');
---

<section class="section pricing-section" id="pricing">
  <div class="shell pricing-shell">
    <div class="pricing-top reveal">
      <div>
        <Kicker tone="paper">Packs per server</Kicker>
        <h2>Choose a credit pack for your server.</h2>
      </div>
      <div class="pricing-summary">
        <p>
          Packs are prepaid credits for one Discord server. Pay once, activate in
          Discord, and spend credits on actions. Wallet account, purchase, activation,
          and order recovery live in the billing workspace.
        </p>
        <div class="pricing-summary-actions">
          <a class="pricing-start" href={siteMeta.accountUrl}>Create account <span>↗</span></a>
          <a class="pricing-start secondary" href={siteMeta.installUrl}>Start trial <span>↗</span></a>
        </div>
      </div>
    </div>

    <div class="pricing-board reveal">
      <div class="pricing-board-header">
        <span>SERVER CREDIT PACKS</span>
        <span>{trialPack.name}: {trialPack.duration} / {trialPack.credits} / {trialPack.storage}</span>
      </div>

      <div class="pricing-table-wrap">
        <table class="pricing-table">
          <colgroup>
            <col />
            {packOptions.map((pack) => <col class:list={[pack.featured && 'featured-col']} />)}
          </colgroup>
          <thead>
            <tr>
              <th scope="col">
                <span>Pack</span>
                <strong>One-time</strong>
              </th>
              {
                packOptions.map((pack) => (
                  <th scope="col" class:list={[pack.featured && 'featured']}>
                    <span>{pack.badge}</span>
                    <strong>{pack.name}</strong>
                    <em>{pack.price} once</em>
                    <a class="plan-buy" href={packCheckoutUrl(pack.slug)}>Buy {pack.name}</a>
                  </th>
                ))
              }
            </tr>
          </thead>
          <tbody>
            {
              packRows.map((row) => (
                <tr>
                  <th scope="row">{row.label}</th>
                  {row.values.map((value) => <td>{value}</td>)}
                </tr>
              ))
            }
            <tr class="payment-row">
              <th scope="row">Payment rail</th>
              {packOptions.map(() => <td>Native SOL transfer</td>)}
            </tr>
          </tbody>
        </table>
      </div>

      <div class="pricing-footer">
        <p>Representative credit costs: {actionCostSummary}. Expensive actions cost more credits.</p>
        <p>Checkout requires a wallet account. Paid SOL orders are verified before any credits are granted.</p>
        <a class="text-link" href={siteMeta.billingUrl}>
          Open billing <span>↗</span>
        </a>
      </div>
    </div>
  </div>
</section>
