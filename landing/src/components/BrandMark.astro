---
interface Props {
  variant?: 'full' | 'simple';
  class?: string;
}

const { variant = 'full', class: className = 'brand-mark' } = Astro.props;
---

<svg class={className} viewBox="0 0 40 40" aria-hidden="true">
  <rect x="1" y="1" width="38" height="38" rx="12" fill="currentColor" />
  <circle cx="13" cy="13" r="5" fill="#050505" />
  <circle cx="27" cy="13" r="5" fill="#050505" />
  <ellipse cx="20" cy="21" rx="12" ry="11" fill="#f5f5f0" />
  {
    variant === 'full' ? (
      <>
        <ellipse
          cx="15.5"
          cy="20"
          rx="3.5"
          ry="4.5"
          fill="#050505"
          transform="rotate(18 15.5 20)"
        />
        <ellipse
          cx="24.5"
          cy="20"
          rx="3.5"
          ry="4.5"
          fill="#050505"
          transform="rotate(-18 24.5 20)"
        />
        <circle cx="15.7" cy="19.6" r="1" fill="#f5f5f0" />
        <circle cx="24.3" cy="19.6" r="1" fill="#f5f5f0" />
        <path
          d="M18 25.5c1.2.9 2.8.9 4 0"
          fill="none"
          stroke="#050505"
          stroke-width="1.8"
          stroke-linecap="round"
        />
      </>
    ) : (
      <>
        <ellipse cx="15.5" cy="20" rx="3.5" ry="4.5" fill="#050505" />
        <ellipse cx="24.5" cy="20" rx="3.5" ry="4.5" fill="#050505" />
      </>
    )
  }
</svg>
