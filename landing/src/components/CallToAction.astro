---
import LogoMark from './LogoMark.astro';
import { siteMeta } from '../data/landing';
import Button from './ui/Button.astro';
import Kicker from './ui/Kicker.astro';
---

<section class="cta-section">
  <div class="cta-grid" aria-hidden="true"></div>
  <div class="shell cta-inner reveal">
    <div class="cta-mark" aria-hidden="true">
      <LogoMark class="cta-logo" />
    </div>
    <Kicker tone="paper">Install, trial, upgrade when ready.</Kicker>
    <h2>Give your community<br />a reliable assistant.</h2>
    <p>Start with included trial credits, configure Panda in Discord, and upgrade only when the server is ready.</p>
    <div class="cta-actions">
      <Button href={siteMeta.installUrl} variant="dark" external>
        Start trial <span>→</span>
      </Button>
    </div>
  </div>
</section>
