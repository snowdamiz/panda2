---
import BrandMark from './BrandMark.astro';
import { footerGroups } from '../data/landing';
---

<footer class="site-footer">
  <div class="shell footer-grid">
    <div>
      <a class="brand footer-brand" href="#top">
        <BrandMark variant="simple" />
        <span>PANDA</span>
      </a>
      <p>Advanced Discord LLM assistant.<br />Open source, self-hosted, model-agnostic.</p>
    </div>
    <div class="footer-links">
      {
        footerGroups.map((group) => (
          <div>
            <small>{group.title}</small>
            {
              group.links.map((link) => (
                <a
                  href={link.href}
                  target={link.external ? '_blank' : undefined}
                  rel={link.external ? 'noreferrer' : undefined}
                >
                  {link.label}
                </a>
              ))
            }
          </div>
        ))
      }
    </div>
  </div>
  <div class="shell footer-bottom">
    <span>© <span data-year></span> Panda</span><span>Built for Discord. Routed by OpenRouter.</span>
  </div>
</footer>
