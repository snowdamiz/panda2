---
import LogoMark from './LogoMark.astro';
import { heroMeta, marqueeItems, planOptions, siteMeta } from '../data/landing';
import Button from './ui/Button.astro';
---

<section class="hero" id="top">
  <div class="hero-grid" aria-hidden="true"></div>
  <div class="shell hero-layout">
    <div class="hero-copy reveal">
      <div class="eyebrow"><span></span> Hosted Discord assistant</div>
      <h1>Your server,<br /><em>with a better brain.</em></h1>
      <p class="hero-lede">
        Panda brings managed AI responses, server knowledge, web search, schedules, and
        usage controls into Discord without asking your members to wire up provider accounts.
      </p>
      <div class="hero-actions">
        <Button href={siteMeta.installUrl}>
          Start a trial
          <svg viewBox="0 0 18 18" aria-hidden="true"><path d="M4 9h10M10 5l4 4-4 4" /></svg>
        </Button>
        <Button href="/#pricing" variant="ghost">
          View pricing
        </Button>
      </div>
      <div class="hero-meta" aria-label="Technology stack">
        {
          heroMeta.map((item, index) => (
            <>
              <span>{item}</span>
              {index < heroMeta.length - 1 && <i></i>}
            </>
          ))
        }
      </div>
    </div>

    <div class="hero-stage reveal reveal-delay" id="demo">
      <div class="orbit orbit-one" aria-hidden="true"></div>
      <div class="orbit orbit-two" aria-hidden="true"></div>
      <div class="discord-window">
        <div class="window-topbar">
          <div class="window-channel">
            <span class="hash">#</span>
            <span>product-lab</span>
          </div>
          <div class="window-actions" aria-hidden="true">
            <span></span><span></span><span></span>
          </div>
        </div>

        <div class="status-bar">
          <span class="status-indicator"><i></i> Panda is online</span>
          <span class="trial-pill">
            <span class="trial-label">TRIAL</span>
            <span>{planOptions[0].aiResponses}</span>
          </span>
        </div>

        <div class="chat-body">
          <article class="message message-user">
            <div class="avatar avatar-user" aria-hidden="true">S</div>
            <div class="message-content">
              <div class="message-author">snow <time>Today at 10:42 AM</time></div>
              <p>
                <strong>Panda</strong>, summarize the launch thread and turn the open questions into
                action items.
              </p>
            </div>
          </article>

          <article class="message message-panda">
            <div class="avatar avatar-panda" aria-hidden="true">
              <LogoMark class="avatar-logo" loading="eager" size={30} />
            </div>
            <div class="message-content">
              <div class="message-author">Panda <span class="bot-tag">APP</span> <time>Today at 10:42 AM</time></div>
              <div class="typing-line" data-typing-line>
                <span class="typing-dot"></span><span class="typing-dot"></span><span class="typing-dot"></span>
              </div>
              <div class="panda-response" data-panda-response>
                <p>The launch is on track. Three decisions still need owners:</p>
                <ol>
                  <li><span>Finalize onboarding copy</span><small>Owner needed · #launch</small></li>
                  <li><span>Confirm plan limits</span><small>Assigned to Maya · #ops</small></li>
                  <li><span>Schedule moderator walkthrough</span><small>Due Friday · #community</small></li>
                </ol>
                <div class="response-footer">
                  <span>{planOptions[0].label} plan</span>
                  <span>3 sources</span>
                  <span>1.8s</span>
                </div>
              </div>
            </div>
          </article>
        </div>

        <div class="composer">
          <button type="button" aria-label="Add attachment">+</button>
          <span>Message #product-lab</span>
          <div class="composer-icons" aria-hidden="true"><i></i><i></i></div>
        </div>
      </div>

      <div class="floating-chip chip-context"><span>↳</span> Thread context</div>
      <div class="floating-chip chip-private"><span>◉</span> Memory: opt-in</div>
    </div>
  </div>

  <div class="hero-marquee" aria-label="Product capabilities">
    <div class="marquee-track">
      {
        [...marqueeItems, ...marqueeItems].map((item, index) => (
          <>
            <span aria-hidden={index >= marqueeItems.length ? 'true' : undefined}>{item}</span>
            <i aria-hidden={index >= marqueeItems.length ? 'true' : undefined}>✦</i>
          </>
        ))
      }
    </div>
  </div>
</section>
