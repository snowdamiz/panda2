---
import { privacyItems, siteMeta } from '../data/landing';
import Button from './ui/Button.astro';
import Kicker from './ui/Kicker.astro';
---

<section class="section privacy-section" id="privacy">
  <div class="privacy-orb" aria-hidden="true"></div>
  <div class="shell privacy-layout">
    <div class="privacy-copy reveal">
      <Kicker>Privacy from first principles</Kicker>
      <h2>Memory should be invited,<br />not assumed.</h2>
      <p>
        Panda defaults to minimal retention. Server knowledge is opt-in, user memory requires
        separate consent, and raw Discord content is treated as untrusted context.
      </p>
      <Button href={siteMeta.privacyUrl}>
        Read privacy policy
      </Button>
    </div>
    <div class="privacy-list reveal">
      {
        privacyItems.map((item) => (
          <div>
            <span class="privacy-icon">{item.icon}</span>
            <p><b>{item.title}</b><small>{item.detail}</small></p>
            <em>{item.state}</em>
          </div>
        ))
      }
    </div>
  </div>
</section>
