---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Kicker from '../components/ui/Kicker.astro';
import { packOptions } from '../data/landing';
import BaseLayout from '../layouts/BaseLayout.astro';

const billingApiBase = import.meta.env.PUBLIC_PANDA_API_BASE_URL || (import.meta.env.DEV ? 'http://localhost:8080' : 'https://panda-assistant.fly.dev');
const defaultPack = packOptions.find((pack) => pack.featured) ?? packOptions[0];
---

<BaseLayout
  title="Panda billing - Buy a credit pack"
  description="Activate a prepaid Panda credit pack for one Discord server with a connected wallet and optional coupon code."
>
  <Header />
  <main id="main" class="app-page billing-page">
    <section class="shell billing-shell">
      <div class="app-page-heading billing-heading reveal">
        <div>
          <Kicker tone="paper">Billing</Kicker>
          <h1>Buy the pack. Get the key.</h1>
        </div>
        <p>
          Pick a credit pack, add a coupon if you have one, and approve the wallet
          prompt. Panda verifies the payment and reveals one activation key for Discord.
        </p>
      </div>

      <div class="checkout-card reveal" data-sol-pay data-api-base={billingApiBase}>
        <form class="checkout-form" data-sol-form>
          <fieldset>
            <legend>Pack</legend>
            <div class="checkout-plans" role="group" aria-label="Pack">
              {
                packOptions.map((pack) => (
                  <button
                    type="button"
                    class:list={['checkout-plan', pack.slug === defaultPack.slug && 'active']}
                    data-sol-pack={pack.slug}
                    data-sol-pack-label={pack.name}
                    aria-pressed={pack.slug === defaultPack.slug ? 'true' : 'false'}
                  >
                    <span class="checkout-plan-badge">{pack.badge}</span>
                    <strong class="checkout-plan-name">{pack.name}</strong>
                    <em class="checkout-plan-rate">{pack.price} once</em>
                    <span class="checkout-plan-limits">
                      <span>{pack.credits}</span>
                      <span>{pack.storage}</span>
                      <span>{pack.retention}</span>
                    </span>
                  </button>
                ))
              }
            </div>
          </fieldset>

          <label class="checkout-coupon">
            <span>Coupon code</span>
            <input data-sol-coupon name="coupon_code" autocomplete="off" spellcheck="false" />
          </label>

          <button class="checkout-buy" type="submit" data-sol-buy>Buy Plus Pack</button>
        </form>

        <div class="checkout-result" data-sol-result hidden>
          <p class="sol-status" data-sol-status aria-live="polite"></p>
          <div class="checkout-key" data-sol-key-box hidden>
            <span>Activation key</span>
            <code data-sol-key></code>
            <button type="button" data-sol-copy>Copy key</button>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
