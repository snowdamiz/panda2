---
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { siteMeta } from '../../data/landing';
import BaseLayout from '../../layouts/BaseLayout.astro';

const setupSteps = [
  {
    number: '01',
    title: 'Talk to Panda',
    body: 'Open your server and ask Panda to help set itself up. It can inspect current settings, then ask what roles, channels, and tools you want configured.',
  },
  {
    number: '02',
    title: 'Confirm the setup',
    body: 'Choose Panda admin and moderator roles, allowed operating channels, per-tool role access, and the prompt or personality you want Panda to use.',
  },
  {
    number: '03',
    title: 'Use slash commands only when needed',
    body: 'Most setup can happen in chat. Use `/billing` when you need to paste an activation key or review plan, quota, and trial status.',
  },
] as const;
---

<BaseLayout title="Panda is installed" description="Panda has been installed. Finish setup from your Discord server.">
  <Header solid />
  <main id="main" class="install-result-page">
    <section class="shell install-result install-result-complete">
      <div class="install-result-copy">
        <span>INSTALL DETECTED</span>
        <h1>Panda is installed.</h1>
        <p>Open Discord and configure Panda by chatting with it. Roles, channels, tool access, prompt, and personality can all be handled conversationally.</p>
        <div class="install-result-actions">
          <a href="https://discord.com/channels/@me" data-discord-server-link>Open Discord</a>
          <a href={siteMeta.accountUrl}>Account</a>
          <a href={siteMeta.supportUrl}>Support</a>
        </div>
      </div>
      <div class="install-next-steps" aria-label="Discord setup steps">
        {setupSteps.map((step) => (
          <article class="install-step">
            <span>{step.number}</span>
            <div>
              <h2>{step.title}</h2>
              <p>{step.body}</p>
            </div>
          </article>
        ))}
        <div class="install-command-strip" aria-label="Suggested setup prompts">
          <span>Panda help me set you up</span>
          <span>allow #panda</span>
          <span>/billing</span>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <script>
    const params = new URLSearchParams(window.location.search);
    const guildID = params.get('guild_id')?.trim();
    if (guildID) {
      try {
        window.localStorage.setItem('panda.guildAccount.v1', JSON.stringify({
          guildID,
          updatedAt: new Date().toISOString(),
        }));
      } catch {
        // Account can still be opened manually with ?guild_id=...
      }
      const discordServerLink = document.querySelector<HTMLAnchorElement>('[data-discord-server-link]');
      if (discordServerLink) {
        discordServerLink.href = `https://discord.com/channels/${encodeURIComponent(guildID)}`;
      }
    }
  </script>
</BaseLayout>
