---
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { siteMeta } from '../../data/landing';
import BaseLayout from '../../layouts/BaseLayout.astro';

const setupSteps = [
  {
    number: '01',
    title: 'Open Discord',
    body: 'Open the server from here, then ask Panda to start the setup wizard in the channel where admins coordinate.',
  },
  {
    number: '02',
    title: 'Walk through setup',
    body: 'Panda will use Discord buttons, menus, and modals to choose a template, tune copy and roles, and preview changes.',
  },
  {
    number: '03',
    title: 'Apply in Discord',
    body: 'Press the native confirmation button after checking the diff. Panda applies the setup in the background and records progress.',
  },
] as const;
---

<BaseLayout title="Panda is installed" description="Panda has been installed. Finish setup from your Discord server.">
  <Header solid />
  <main id="main" class="install-result-page">
    <section class="shell install-result install-result-complete">
      <div class="install-result-copy">
        <span>INSTALL DETECTED</span>
        <h1>Panda is installed.</h1>
        <p>Open Discord and finish setup with Panda's native admin wizard. Panda can build roles, channels, tickets, onboarding, and its own access controls after confirmation.</p>
        <div class="install-result-actions">
          <a href="https://discord.com/channels/@me" data-discord-server-link>Open Discord</a>
          <a href={siteMeta.accountUrl}>Account</a>
          <a href={siteMeta.supportUrl}>Support</a>
        </div>
      </div>
      <div class="install-next-steps" aria-label="Discord setup steps">
        {setupSteps.map((step) => (
          <article class="install-step">
            <span>{step.number}</span>
            <div>
              <h2>{step.title}</h2>
              <p>{step.body}</p>
            </div>
          </article>
        ))}
        <div class="install-command-strip" aria-label="Suggested setup prompts">
          <span>Panda start server setup wizard</span>
          <span>Panda walk me through Discord setup</span>
          <span>/billing</span>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <script>
    const params = new URLSearchParams(window.location.search);
    const guildID = params.get('guild_id')?.trim();
    if (guildID) {
      try {
        window.localStorage.setItem('panda.guildAccount.v1', JSON.stringify({
          guildID,
          updatedAt: new Date().toISOString(),
        }));
      } catch {
        // Account can still be opened manually with ?guild_id=...
      }
      const discordServerLink = document.querySelector<HTMLAnchorElement>('[data-discord-server-link]');
      if (discordServerLink) {
        discordServerLink.href = `https://discord.com/channels/${encodeURIComponent(guildID)}`;
      }
    }
  </script>
</BaseLayout>
